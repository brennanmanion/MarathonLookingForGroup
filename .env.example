NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marathon_lfg

# Bungie confidential-client credentials
BUNGIE_CLIENT_ID=your-client-id
BUNGIE_CLIENT_SECRET=your-client-secret
BUNGIE_API_KEY=your-api-key

# Recommended production web/PWA setup is same-origin:
#   https://lfg.example.com/app/                    -> browser shell
#   https://lfg.example.com/auth/bungie/callback   -> Bungie callback
# Leave SESSION_COOKIE_DOMAIN blank for same-origin.
BUNGIE_REDIRECT_URI=https://lfg.example.com/auth/bungie/callback
APP_UNIVERSAL_LINK_BASE=https://lfg.example.com
WEB_APP_BASE_URL=https://lfg.example.com/app/
SESSION_COOKIE_DOMAIN=

APP_SESSION_SECRET=replace-with-a-long-random-secret
